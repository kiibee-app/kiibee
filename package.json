{
  "name": "kiibee",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "test:coverage": "turbo run test:coverage",
    "test:ci": "turbo run test:ci",
    "test:watch": "turbo run test:watch",
    "prepare": "husky install",
    "boom": "git add -A && git cz && git push",
    "audit": "pnpm audit --prod",
    "audit:fix": "pnpm audit fix",
    "dev:web": "turbo run dev --filter=foodime-web",
    "dev:server": "turbo run dev --filter=foodime-server",
    "dev:mobile": "turbo run dev --filter=@foodime/mobile",
    "dev:admin": "turbo run dev --filter=foodime-admin",
    "dev:ai": "turbo run dev --filter=foodime-ai",
    "dev:frontend": "turbo run dev --filter=foodime-web --filter=foodime-admin",
    "dev:backend": "turbo run dev --filter=foodime-server --filter=foodime-ai",
    "dev:all": "turbo run dev --parallel",
    "start:web": "turbo run start --filter=foodime-web",
    "start:server": "turbo run start --filter=foodime-server",
    "start:admin": "turbo run start --filter=foodime-admin",
    "start:ai": "turbo run start --filter=foodime-ai",
    "start:production": "turbo run start --filter=foodime-web --filter=foodime-server --filter=foodime-admin --filter=foodime-ai --parallel",
    "build:web": "turbo run build --filter=foodime-web",
    "build:server": "turbo run build --filter=foodime-server",
    "build:pos": "turbo run build --filter=foodime-pos",
    "build:admin": "turbo run build --filter=foodime-admin",
    "build:ai": "turbo run build --filter=foodime-ai",
    "build:frontend": "turbo run build --filter=foodime-web --filter=foodime-admin",
    "build:backend": "turbo run build --filter=foodime-server --filter=foodime-ai",
    "test:web": "turbo run test --filter=foodime-web",
    "test:server": "turbo run test --filter=foodime-server",
    "test:mobile": "turbo run test --filter=@foodime/mobile",
    "test:admin": "turbo run test --filter=foodime-admin",
    "test:ai": "turbo run test --filter=foodime-ai",
    "lint:web": "turbo run lint --filter=foodime-web",
    "lint:server": "turbo run lint --filter=foodime-server",
    "lint:mobile": "turbo run lint --filter=@foodime/mobile",
    "lint:admin": "turbo run lint --filter=foodime-admin",
    "lint:ai": "turbo run lint --filter=foodime-ai",
    "ai:download-models": "pnpm --filter=foodime-ai download-models",
    "db:generate": "pnpm --filter=foodime-server generate",
    "db:migrate": "pnpm --filter=foodime-server migrate",
    "db:seed": "pnpm --filter=foodime-server seed",
    "db:seed:dev": "pnpm --filter=foodime-server seed:dev",
    "test:e2e": "playwright test",
    "percy:playwright": "percy exec -- playwright test"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@next/swc-linux-arm64-gnu": "^16.0.3",
    "@next/swc-linux-arm64-musl": "^16.0.3",
    "@percy/cli": "^1.31.9",
    "@percy/playwright": "^1.0.10",
    "@playwright/test": "^1.56.1",
    "commitizen": "^4.3.1",
    "cross-env": "^10.1.0",
    "cspell": "^9.2.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^8.57.1",
    "eslint-module-utils": "^2.12.1",
    "husky": "^9.1.7",
    "prettier": "^3.6.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.7.0",
    "turbo": "^2.5.8",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.2.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "@types/express": "4.17.23",
      "nanoid@<3.3.8": ">=3.3.8",
      "esbuild@<=0.24.2": ">=0.25.0",
      "next@>=15.3.0 <15.3.3": ">=15.3.3",
      "tmp@<=0.2.3": ">=0.2.4",
      "next@>=15.0.0 <=15.4.4": ">=15.4.5",
      "next@>=15.0.0-canary.0 <15.4.7": ">=15.4.7",
      "axios@>=1.0.0 <1.12.0": ">=1.12.0",
      "nodemailer@<7.0.7": ">=7.0.7"
    },
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom",
        "i18next"
      ],
      "allowedVersions": {
        "react": "19",
        "react-dom": "19",
        "i18next": "25"
      }
    },
    "ignoredBuiltDependencies": [
      "@vercel/speed-insights"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "dependencies": {
    "@elevenlabs/react": "^0.14.0",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "react-image-crop": "^11.0.10"
  }
}
