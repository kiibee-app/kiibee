{
  "name": "kiibee",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@next/swc-linux-arm64-gnu": "^16.0.3",
    "@next/swc-linux-arm64-musl": "^16.0.3",
    "@percy/cli": "^1.31.9",
    "@percy/playwright": "^1.0.10",
    "@playwright/test": "^1.56.1",
    "commitizen": "^4.3.1",
    "cross-env": "^10.1.0",
    "cspell": "^9.2.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^8.57.1",
    "eslint-module-utils": "^2.12.1",
    "husky": "^9.1.7",
    "prettier": "^3.6.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.7.0",
    "turbo": "^2.5.8",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.2.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "@types/express": "4.17.23",
      "nanoid@<3.3.8": ">=3.3.8",
      "esbuild@<=0.24.2": ">=0.25.0",
      "next@>=15.3.0 <15.3.3": ">=15.3.3",
      "tmp@<=0.2.3": ">=0.2.4",
      "next@>=15.0.0 <=15.4.4": ">=15.4.5",
      "next@>=15.0.0-canary.0 <15.4.7": ">=15.4.7",
      "axios@>=1.0.0 <1.12.0": ">=1.12.0",
      "nodemailer@<7.0.7": ">=7.0.7"
    },
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom",
        "i18next"
      ],
      "allowedVersions": {
        "react": "19",
        "react-dom": "19",
        "i18next": "25"
      }
    },
    "ignoredBuiltDependencies": [
      "@vercel/speed-insights"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "dependencies": {
    "@elevenlabs/react": "^0.14.0",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "react-image-crop": "^11.0.10"
  }
}
