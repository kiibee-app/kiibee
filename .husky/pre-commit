#!/usr/bin/env sh

echo "Running pre-commit checks..."

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
  echo "No staged files found."
  exit 0
fi

FORMATTABLE_FILES=$(printf '%s\n' "$STAGED_FILES" | grep -E '\.(js|jsx|ts|tsx|json|md|yml|yaml)$' || true)

if [ -n "$FORMATTABLE_FILES" ]; then
  echo "Formatting staged files..."
  for file in $FORMATTABLE_FILES; do
    pnpm exec prettier --write "$file" || exit 1
    git add "$file"
  done
fi

TOUCHED_APPS=""

for app in admin server web; do
  if printf '%s\n' "$STAGED_FILES" | grep -q "^apps/$app/"; then
    TOUCHED_APPS="$TOUCHED_APPS $app"
  fi
done

TOUCHED_APPS=$(echo "$TOUCHED_APPS" | sed 's/^ *//')

if [ -z "$TOUCHED_APPS" ]; then
  echo "No staged app files found. Skipping app lint."
  exit 0
fi

echo "Linting touched apps:$TOUCHED_APPS"

for app in $TOUCHED_APPS; do
  if grep -q '"lint"' "apps/$app/package.json"; then
    pnpm --dir "apps/$app" run lint || exit 1
  else
    echo "Skipping apps/$app lint; no lint script."
  fi
done

echo "Pre-commit checks passed."
