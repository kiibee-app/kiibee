#!/usr/bin/env sh
# Prevents force-pushing or pushing to protected branches.

BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)

IS_FORCE_PUSH=false
for arg in "$@"; do
  case "$arg" in
    --force|-f)
      IS_FORCE_PUSH=true
      ;;
  esac
done

# Block push if branch is protected.
case "$BRANCH" in
  master|main|develop|release-*|patch-*)
    if [ "$IS_FORCE_PUSH" = true ]; then
      echo "Error: Force pushing to protected branch '$BRANCH' is not allowed." >&2
      echo "Please create a feature branch and use pull requests instead." >&2
    else
      echo "Error: Direct pushing to protected branch '$BRANCH' is not allowed." >&2
      echo "Please create a feature branch and use pull requests instead." >&2
    fi
    exit 1
    ;;
esac

exit 0
