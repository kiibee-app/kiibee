{
  "version": 2,
  "builds": [
    {
      "src": "apps/server/package.json",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["apps/server/**"],
        "runtime": "nodejs20.x"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/apps/server/$1"
    }
  ]
}
