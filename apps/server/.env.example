NODE_ENV=development
PORT=4001
DATABASE_URL=postgresql://postgres:897351@localhost:5432/kiibee-local

JWT_ACCESS_SECRET="your-jwt-access-secret"
JWT_REFRESH_SECRET="your-jwt-refresh-secret"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

FRONTEND_URL=http://localhost:3001

#local smtp server for development
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-password"
SENDER_EMAIL=your-email@gmail.com
SENDER_NAME=Kiibee

CORS_ORIGIN=http://localhost:3000,http://localhost:3001
BCRYPT_SALT_ROUNDS=12
CREATOR_SEED_PASSWORD_HASH="your-bcrypt-password-hash"

#bucket config
DO_ACCESS_KEY="your-digitalocean-access-key"
DO_SECRET_KEY="your-digitalocean-secret-key"
DO_REGION="your-digitalocean-region"
DO_BUCKET="your-digitalocean-bucket"

#epay config
EPAY_API_KEY=your-epay-api-key
EPAY_POINT_OF_SALE_ID=your-epay-point-of-sale-id
EPAY_BASE_URL=https://payments.epay.eu
