NODE_ENV=development
PORT=4001
DATABASE_URL=postgresql://postgres:897351@localhost:5432/kiibee-local

JWT_ACCESS_SECRET="your-jwt-access-secret"
JWT_REFRESH_SECRET="your-jwt-refresh-secret"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

FRONTEND_URL=http://localhost:3001

#local smtp server for development
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-password"
SENDER_EMAIL=your-email@gmail.com
SENDER_NAME=Kiibee

CORS_ORIGIN=http://localhost:3000,http://localhost:3001
BCRYPT_SALT_ROUNDS=12

# DigitalOcean Spaces (S3-compatible media storage)
DO_SPACES_KEY="your-do-spaces-key"
DO_SPACES_SECRET="your-do-spaces-secret"
DO_SPACES_ENDPOINT="https://fra1.digitaloceanspaces.com"
DO_SPACES_BUCKET="kiibee-media"
DO_SPACES_REGION=fra1
DO_SPACES_CDN_URL="https://kiibee-media.fra1.cdn.digitaloceanspaces.com"

# Cloudflare (Stream / CDN - migration source)
CLOUDFLARE_SERVICE_TOKEN="your-service-token"
CLOUDFLARE_ACCOUNT_ID="your-account-identifier"
CLOUDFLARE_AUTH_EMAIL="your-auth-email"
CLOUDFLARE_AUTH_KEY="your-global-api-key"

# Umbraco source database (SQL Server - for migration only)
UMBRACO_DB_CONNECTION_STRING="Server=your-server;Database=UmbracoCMS;User Id=sa;Password=your-password;"
